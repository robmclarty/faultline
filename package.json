{
  "name": "@robmclarty/faultline",
  "version": "0.4.0",
  "type": "module",
  "description": "Reverse-engineer (or 'decompile') brownfield codebases into abstract product specs.",
  "license": "MIT",
  "author": "Rob McLarty",
  "bin": {
    "faultline": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "npm run lint:code && npm run lint:markdown && npm run lint:agents && npm run lint:fallow",
    "lint:code": "oxlint --ignore-pattern examples",
    "lint:markdown": "markdownlint-cli2 '**/*.md'",
    "lint:agents": "agnix",
    "lint:fallow": "npx fallow",
    "typecheck": "tsc --noEmit --pretty",
    "prepublishOnly": "npm run build",
    "coverage": "vitest run --coverage",
    "test": "npm run typecheck && npm run lint && npm run test:unit",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "13.0.0"
  },
  "devDependencies": {
    "@types/node": "22.15.2",
    "@vitest/coverage-v8": "3.1.2",
    "agnix": "0.17.0",
    "fallow": "2.22.4",
    "markdownlint-cli2": "0.21.0",
    "oxlint": "0.16.6",
    "ridgeline": "0.5.6",
    "typescript": "5.8.3",
    "vitest": "3.1.2"
  }
}
